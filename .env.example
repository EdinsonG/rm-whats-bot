# --- Configuración de IA (Groq Cloud) ---
# Consigue tu key en https://console.groq.com/
GROQ_API_KEY=gsk_tu_clave_aqui_no_la_compartas

# Modelo recomendado por su balance velocidad/inteligencia
MODEL_NAME=llama-3.3-70b-versatile

# --- Configuración del Servidor ---
# Puerto para el Health Check (necesario para Render/Railway)
PORT=3000

# --- Notas ---
# No rodees los valores con comillas a menos que tengan espacios.